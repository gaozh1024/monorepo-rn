{
  "name": "@panther-expo/ui",
  "version": "0.0.1",
  "description": "基于 Gluestack UI + NativeWind 的 React Native 组件库",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "pe-ui": "./scripts/generate-theme.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --treeshake --splitting --external react-native --external react --external @expo/html-elements",
    "lint": "eslint src",
    "generate-theme": "node scripts/generate-theme.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@panther-expo/theme": "workspace:*",
    "@expo/html-elements": "^0.11.0",
    "@gluestack-ui/core": "^3.0.12",
    "@gluestack-ui/utils": "^3.0.15",
    "@gorhom/bottom-sheet": "^5.0.0",
    "@legendapp/motion": "^2.4.0",
    "nativewind": "^4.2.1",
    "react-native-svg": "^15.0.0",
    "react-stately": "^3.35.0",
    "tailwind-variants": "^0.1.20"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "^0.76.0 || ^0.79.0 || ^0.81.0",
    "tailwindcss": "^3.4.0",
    "react-native-reanimated": ">=3.16.0",
    "react-native-gesture-handler": ">=2.16.1"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "~19.0.0"
  }
}

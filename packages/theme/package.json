{
  "name": "@panther-expo/theme",
  "version": "0.0.1",
  "description": "UI主题系统",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./colors": {
      "types": "./dist/colors.d.ts",
      "default": "./dist/colors.js"
    },
    "./palette": {
      "types": "./dist/palette.d.ts",
      "default": "./dist/palette.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/colors.ts src/palette.ts --format cjs,esm --dts --treeshake --splitting",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "^0.76.0 || ^0.79.0 || ^0.81.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "~19.0.0"
  }
}

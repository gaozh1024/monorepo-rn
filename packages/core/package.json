{
  "name": "@panther-expo/core",
  "version": "0.0.1",
  "description": "核心基础设施 - API客户端和存储封装",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "default": "./dist/storage/index.js"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "default": "./dist/query/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "default": "./dist/logger/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/api/index.ts src/storage/index.ts src/query/index.ts src/logger/index.ts --format cjs,esm --dts --treeshake --splitting",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "expo-secure-store": "~15.0.8"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "^0.76.0 || ^0.79.0 || ^0.81.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "~19.0.0",
    "@tanstack/react-query": "^5.0.0"
  }
}

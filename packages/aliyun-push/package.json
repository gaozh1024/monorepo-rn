{
  "name": "@gaozh1024/aliyun-push",
  "version": "0.1.0",
  "description": "Aliyun mobile push package for Expo / React Native with service helpers, provider, and Expo config plugin.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "plugin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugin": "./plugin/index.js",
    "./plugin/withAliyunPush": "./plugin/withAliyunPush.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "aliyun-react-native-push": ">=1 <2",
    "expo": ">=53 <55",
    "react": ">=18.2.0",
    "react-native": ">=0.79 <0.82"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "keywords": [
    "aliyun",
    "push",
    "react-native",
    "expo",
    "notification"
  ],
  "license": "MIT"
}

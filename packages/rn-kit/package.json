{
  "name": "@gaozh1024/rn-kit",
  "version": "0.5.0",
  "description": "Panther Expo Framework - All-in-one React Native framework",
  "bin": {
    "rn-kit": "./bin/rn-kit.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "init-ai",
    "README.md",
    "docs",
    "AI_USAGE.md",
    "TAILWIND_SETUP.md",
    "ai-manifest.json",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.web.mjs",
      "react-native": "./dist/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/drawer": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.8.5",
    "@tanstack/react-query": "^5.0.0",
    "clsx": "^2.1.0",
    "nativewind": "^4.0.0",
    "react-native-svg": "^14.0.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@expo/vector-icons": ">=14 <16",
    "expo": ">=53 <55",
    "expo-image": ">=2.4.1 <4",
    "expo-linear-gradient": ">=14 <16",
    "react": ">=18.2.0",
    "react-native": ">=0.79 <0.82",
    "react-native-gesture-handler": ">=2.0.0 <3",
    "react-native-reanimated": ">=3.17.0 <5",
    "react-native-safe-area-context": ">=4.0.0 <6",
    "react-native-screens": ">=4.0.0 <5",
    "react-native-worklets": ">=0.5.0 <0.6.0"
  },
  "peerDependenciesMeta": {
    "react-native-worklets": {
      "optional": true
    }
  },
  "devDependencies": {
    "@expo/vector-icons": "~15.1.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.73.0",
    "expo": "~54.0.33",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8"
  },
  "keywords": [
    "@gaozh1024",
    "@gaozh1024/rn-kit",
    "rn-kit",
    "react-native",
    "framework",
    "ui",
    "theme",
    "navigation"
  ],
  "license": "MIT",
  "module": "dist/index.mjs"
}

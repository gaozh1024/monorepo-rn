# ============================================================================
# 📦 @panther-expo/utils - NPM Ignore
# ============================================================================

# ----------------------------------------------------------------------------
# 源代码 (Source Code - 只发布编译后的代码)
# ----------------------------------------------------------------------------
src/
*.ts
!*.d.ts

# ----------------------------------------------------------------------------
# 测试 (Tests)
# ----------------------------------------------------------------------------
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/

# ----------------------------------------------------------------------------
# 配置 (Configs)
# ----------------------------------------------------------------------------
vitest.config.ts
tsconfig.json
.eslintrc.js
.prettierrc

# ----------------------------------------------------------------------------
# 开发文件 (Development Files)
# ----------------------------------------------------------------------------
node_modules/
*.log
.env
.env.local

# ----------------------------------------------------------------------------
# Git
# ----------------------------------------------------------------------------
.git/
.gitignore

# ----------------------------------------------------------------------------
# 其他 (Others)
# ----------------------------------------------------------------------------
*.md
!README.md
CHANGELOG.md
docs/

{
  "name": "@gaozh1024/monorepo",
  "private": true,
  "description": "React Native Monorepo - Core packages for building React Native apps",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "yalc:publish": "pnpm -r --filter='@gaozh1024/*' exec yalc publish",
    "yalc:push": "pnpm -r --filter='@gaozh1024/*' exec yalc push",
    "yalc:update": "pnpm -r --filter='@gaozh1024/*' exec yalc push --replace",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@testing-library/react-native": "^13.3.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}

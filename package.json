{
  "name": "@gaozh1024/monorepo",
  "private": true,
  "description": "React Native Monorepo - Core packages for building React Native apps",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "template:pack": "cd templates/rn-starter && npm pack",
    "template:publish": "cd templates/rn-starter && npm publish --access public",
    "test-app": "cd examples/test-app && npm start",
    "yalc:publish": "pnpm -r --filter='@gaozh1024/*' exec yalc publish",
    "yalc:push": "pnpm -r --filter='@gaozh1024/*' exec yalc push",
    "yalc:update": "pnpm -r --filter='@gaozh1024/*' exec yalc push --replace",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@expo/cli": "~0.21.8",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "metro": "~0.80.12",
    "metro-babel-transformer": "~0.80.12",
    "metro-cache": "~0.80.12",
    "metro-config": "~0.80.12",
    "metro-resolver": "~0.80.12",
    "metro-runtime": "~0.80.12",
    "metro-source-map": "~0.80.12",
    "metro-symbolicate": "~0.80.12",
    "metro-transform-worker": "~0.80.12",
    "msw": "^2.12.10",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    "packages/*",
    "templates/*",
    "examples/*"
  ],
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}

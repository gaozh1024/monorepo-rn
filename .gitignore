# ============================================================================
# 📁 Panther Expo Framework - Git Ignore
# ============================================================================

# ----------------------------------------------------------------------------
# 依赖 (Dependencies)
# ----------------------------------------------------------------------------
node_modules/
package-lock.json
npm-shrinkwrap.json
.pnp
.pnp.js
.yarn/install-state.gz
.pnpm-store/

# ----------------------------------------------------------------------------
# 构建输出 (Build Outputs)
# ----------------------------------------------------------------------------
# 根目录
dist/
build/
out/

# 各包构建输出 (packages/*)
packages/*/dist/
packages/*/build/

# ----------------------------------------------------------------------------
# 测试 (Testing)
# ----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# ----------------------------------------------------------------------------
# 环境变量 (Environment Variables)
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# ----------------------------------------------------------------------------
# 日志 (Logs)
# ----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ----------------------------------------------------------------------------
# 编辑器 (Editor)
# ----------------------------------------------------------------------------
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IDEA
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# 运行时 (Runtime)
# ----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock

# ----------------------------------------------------------------------------
# 缓存 (Cache)
# ----------------------------------------------------------------------------
.eslintcache
.stylelintcache
.parcel-cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ----------------------------------------------------------------------------
# TypeScript
# ----------------------------------------------------------------------------
*.tsbuildinfo

# ----------------------------------------------------------------------------
# 可选 (Optional)
# ----------------------------------------------------------------------------
*.tgz
*.tar.gz

# ----------------------------------------------------------------------------
# 项目特定 (Project Specific)
# ----------------------------------------------------------------------------
examples/
examples/**

# yalc本地发布
.yalc/
yalc.lock

# 临时文件
tmp/
temp/
*.tmp

# 本地历史
.history/

# Expo/React Native
.expo/
.expo-shared/
expo-env.d.ts
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# Metro
.metro-health-check*

# Vitest
.vitest/

# HarmonyOS / Hvigor
.hvigor/

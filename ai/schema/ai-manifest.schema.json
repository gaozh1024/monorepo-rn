{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gaozh1024.github.io/panther/ai-manifest.schema.json",
  "title": "Panther AI Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageName",
    "version",
    "role",
    "summary",
    "entrypoints",
    "installation",
    "recommendedUsage",
    "stableApis",
    "compatibilityNotes",
    "antiPatterns",
    "canonicalExamples",
    "docs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "packageName": {
      "type": "string",
      "pattern": "^(@[a-z0-9._-]+\\/)?[a-z0-9._-]+$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "enum": ["core-framework", "feature-package", "template", "integration-plugin", "tooling"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "recommended"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(\\.|\\./[A-Za-z0-9._/-]+)$"
          },
          "kind": {
            "type": "string",
            "enum": ["runtime", "plugin", "cli", "types"]
          },
          "recommended": {
            "type": "boolean"
          }
        }
      }
    },
    "installation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageManagerCommand", "projectTypes", "peerDependencies"],
      "properties": {
        "packageManagerCommand": {
          "type": "string",
          "minLength": 1
        },
        "projectTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["expo", "react-native", "template", "node"]
          }
        },
        "peerDependencies": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "recommendedUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimumSetup"],
      "properties": {
        "primaryProvider": {
          "type": "string"
        },
        "canonicalTemplate": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._/-]+$"
        },
        "minimumSetup": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "stableApis": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "compatibilityNotes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "antiPatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "canonicalExamples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
          }
        }
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*(^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
      }
    }
  }
}

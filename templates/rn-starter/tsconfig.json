{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@panther-expo/core": ["./node_modules/@panther-expo/core"],
      "@panther-expo/core/*": ["./node_modules/@panther-expo/core/*"],
      "@panther-expo/theme": ["./node_modules/@panther-expo/theme"],
      "@panther-expo/theme/*": ["./node_modules/@panther-expo/theme/*"],
      "@panther-expo/ui": ["./node_modules/@panther-expo/ui"],
      "@panther-expo/utils": ["./node_modules/@panther-expo/utils"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}

{
  "name": "@gaozh1024/expo-starter",
  "version": "0.2.16",
  "description": "Expo starter template based on @gaozh1024/rn-kit",
  "main": "index.js",
  "files": [
    ".gitignore",
    "App.tsx",
    "index.js",
    "README.md",
    "AI_USAGE.md",
    "app.json",
    "ai-manifest.json",
    "assets",
    "babel.config.js",
    "global.css",
